{
	"compilerOptions": {
		"target": "ES2022",
		"lib": [
			"DOM",
			"ES2022",
			"DOM.Iterable"
		],
		"checkJs": true,
		"strict": true,
		"strictNullChecks": false,
		"strictPropertyInitialization": false,
		"noImplicitAny": false
	},
	"include": [
		"**/*.js",
		"types/*.ts"
	],
	"exclude": [
		"~*"
	]
}
